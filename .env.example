# Skopiuj ten plik jako .env i uzupełnij wartości
# cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_DB=uni_calendar
POSTGRES_USER=postgres
POSTGRES_PASSWORD=zmien_na_silne_haslo

# ── Django ────────────────────────────────────────────
SECRET_KEY=zmien-na-dlugi-losowy-ciag-znakow
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Django Superuser (tworzony automatycznie) ─────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=zmien_na_silne_haslo

# ── CORS ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
